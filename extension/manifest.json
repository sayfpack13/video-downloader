{

  "manifest_version": 3,

  "name": "Video Downloader",

  "version": "1.15.4",

  "description": "Detect HLS streams on any site and bulk-download videos as MP4 via local ffmpeg helper.",

  "permissions": ["storage", "cookies", "tabs", "sidePanel", "nativeMessaging", "scripting", "webNavigation"],

  "host_permissions": ["<all_urls>"],

  "background": {

    "service_worker": "background/service-worker.js"

  },

  "action": {

    "default_title": "Video Downloader",

    "default_icon": {

      "16": "icons/icon16.png",

      "48": "icons/icon48.png",

      "128": "icons/icon128.png"

    }

  },

  "side_panel": {

    "default_path": "sidepanel/panel.html"

  },

  "content_scripts": [

    {

      "matches": ["<all_urls>"],

      "exclude_matches": [

        "*://chrome.google.com/*",

        "*://chromewebstore.google.com/*",

        "*://newtab/*"

      ],

      "js": ["content/detect.js"],

      "run_at": "document_start",

      "all_frames": false

    }

  ],

  "icons": {

    "16": "icons/icon16.png",

    "48": "icons/icon48.png",

    "128": "icons/icon128.png"

  }

}

